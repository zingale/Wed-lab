&constants
/

&grid
    w_osc = 10 ! 10 Oscillatory region weight parameter
    w_exp = 2  ! 2 Exponential region weight parameter
    w_ctr = 10 ! 10 Central region weight parameter
/


&model
    model_type = 'EVOL'  ! Obtain stellar structure from an evolutionary model
    file = '{model_file}' ! File name of the evolutionary model
    file_format = 'GSM' ! File format of the evolutionary model
/

&mode
    l = 0                ! Harmonic degree
/

&mode
    l = 1                ! Harmonic degree
/

&mode
    l = 2                ! Harmonic degree
/

&mode
    l = 3                ! Harmonic degree
/

&num
    diff_scheme = 'MAGNUS_GL6' ! 'COLLOC_GL2', 'COLLOC_GL4', 'COLLOC_GL6', 'MAGNUS_GL2', 'MAGNUS_GL4', 'MAGNUS_GL6'
    n_iter_max = 50 ! 50 Maximum number of iterations in root-finding algorithm
/

&osc
    inner_bound = 'REGULAR' ! Inner boundary conditions
    outer_bound = 'JCD' ! 'VACUUM', 'JCD', 'DZIEM', 'UNNO', 'ISOTHERMAL', 'GAMMA' ! Outer boundary conditions
    variables_set = 'JCD' ! 'GYRE', 'JCD', 'DZIEM', 'MIX', 'LAGP'

    alpha_gam = 1. ! 1.
    alpha_pi = 0. ! 1.
    x_atm = 0.9 ! -1
/


&ad_output
    summary_file = '{summary_file}'  ! File name for summary file
    summary_file_format = 'TXT' ! Format of summary file
    freq_units = 'UHZ'
    summary_item_list = 'id,l,n_p,n_g,n_pg,freq,E_norm,E_p,E_g' ! Items to appear in summary file !j,E,E_p,E_g,M_star,R_star
    !detail_template = '{summary_file}.%id.txt'
    !detail_file_format = 'TXT'
    !detail_item_list = 'x,xi_r,xi_h,rho,As,c_1'
/

&nad_output
/

&rot
/

&scan
    grid_type = 'LINEAR' ! Scan for modes using a uniform-in-period grid; best for g modes
    freq_min = {freq_min} ! Minimum frequency to scan from
    freq_max = {freq_max} ! Maximum frequency to scan to
    n_freq = 600          ! Number of frequency points in scan
    freq_min_units = 'UHZ'
    freq_max_units = 'UHZ'
/

&tide
/