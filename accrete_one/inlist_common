&star_job
  ! see star/defaults/star_job.defaults

  ! save a model at the end of the run
    save_model_when_terminate = .false.
    save_model_filename = ''

  ! initial model
    set_initial_age = .true.
    initial_age = 0d0

    set_initial_model_number = .true.
    initial_model_number = 0

  ! coulomb corrections

    ion_coulomb_corrections = 'PCR2009'
    electron_coulomb_corrections = 'Itoh2002'

  ! display on-screen plots
    pgstar_flag = .true.
    disable_pgstar_during_relax_flag = .false.

/ ! end of star_job namelist


&eos
  ! eos options
  ! see eos/defaults/eos.defaults

    use_OPAL_SCVH = .false.
    use_FreeEOS = .false.
    use_PC = .false.

    ! turn off Skye for speedup
    ! will be missing important coulomb physics
    use_Skye = .false.

    mass_fraction_limit_for_Skye = 1d-10
    use_simple_skye_blends = .true.
    logT_min_for_any_Skye = 7.0d0
    logT_min_for_all_Skye = 7.05d0

/ ! end of eos namelist


&kap
  ! kap options
  ! see kap/defaults/kap.defaults
  use_Type2_opacities = .true.
  Zbase = 0.02

/ ! end of kap namelist


&controls
  ! see star/defaults/controls.defaults

  ! when to stop

     log_max_temp_upper_limit = 9.1d0

  ! wind

  ! atmosphere

  ! rotation

  ! element diffusion

  ! mlt

     use_Ledoux_criterion = .true.
     num_cells_for_smooth_brunt_B = 0
     num_cells_for_smooth_gradL_composition_term = 0

     ! turn off convection to make things easier
     mlt_option = 'none'
     ! mlt_gradT_fraction = 0.0

     prune_bad_cz_min_Hp_height = 0.1d0
     prune_bad_cz_min_log_eps_nuc = 99d0

  ! mixing

  ! timesteps

     delta_lgL_limit = 0.2d0
     delta_lgTeff_limit = 0.05d0 ! orginally 0.01d0

     ! delta_lgT_cntr_limit = 2d-2
     ! delta_lgRho_cntr_limit = 5d-3

     ! time_delta_coeff = 2.0d0
     ! gold_solver_iters_timestep_limit = 20

     ! we don't care about energy conservation, just the initial model
     limit_for_rel_error_in_energy_conservation = 1d-2
     hard_limit_for_rel_error_in_energy_conservation = 1d-1

  ! mesh

     ! decrease overall resolution to reduce runtime for summer school
     mesh_delta_coeff = 2.5d0

     ! but need to resolve the urca regions for convergence
     xa_function_species(1) = 'na25'
     xa_function_weight(1) = 15
     xa_function_param(1) = 1d-4

     xa_function_species(2) = 'na23'
     xa_function_weight(2) = 20
     xa_function_param(2) = 1d-4

     xa_function_species(3) = 'na24'
     xa_function_weight(3) = 15
     xa_function_param(3) = 1d-4

     xa_function_species(4) = 'o20'
     xa_function_weight(4) = 15
     xa_function_param(4) = 1d-4

     xa_function_species(5) = 'si28'
     xa_function_weight(5) = 15
     xa_function_param(5) = 1d-4

     ! fixing the position of the Lagrangian region of the mesh
     ! helps convergence during accretion
     max_logT_for_k_below_const_q = 100d0
     max_q_for_k_below_const_q = 0.99d0
     min_q_for_k_below_const_q = 0.99d0 !0.9999d0 !0.999d0

     max_logT_for_k_const_mass = 100d0
     max_q_for_k_const_mass = 0.98d0
     min_q_for_k_const_mass = 0.98d0 !0.9995d0 !0.995d0

  ! solver
     ! options for energy conservation (see MESA V, Section 3)
     energy_eqn_option = 'eps_grav'
     use_gold_tolerances = .true.

     !!! help convergence
     max_resid_jump_limit = 1d20
     max_corr_jump_limit = 1d20
     scale_max_correction = 0.1d0

     ! make_gradr_sticky_in_solver_iters = .true.
     ! scale_max_correction_for_negative_surf_lum = .true.

     !!! relax tolerances aggressively for speed (not for production!)
     min_xa_hard_limit = -1d-4 ! originally -1d-5

     convergence_ignore_equL_residuals = .true.

     tol_correction_norm = 3d-4 ! originally 3d-5
     tol_max_correction = 3d-2 ! originally 3d-3
     ! ignore_too_large_correction = .true.
     
     ignore_species_in_max_correction = .true.
     
     gold_tol_residual_norm3 = 1d-5 ! originally 1d-6
     gold_tol_max_residual3 = 2d-3 ! originally 1d-4

     report_solver_progress = .true.

  ! output

     profile_interval = 100000
     history_interval = 1

  ! others

     

/ ! end of controls namelist
